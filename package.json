{
  "name": "foh-task-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "db:sync-dev-migrations": "./scripts/sync-dev-migrations.sh",
    "db:sync-dev-data-local": "node scripts/sync-dev-to-local-data.mjs",
    "db:align-local": "npx supabase link --project-ref gdnauerufpvjjhwshtbv && npx supabase db push --include-all --linked && SUPABASE_TARGET=local npm run db:reset",
    "db:reset": "node scripts/reset-supabase-db.mjs",
    "db:backfill-log-names": "node scripts/backfill-log-names.mjs",
    "cypress:run": "cypress run",
    "cypress:open": "cypress open",
    "test:e2e": "npm run db:reset && start-server-and-test \"vite --host 127.0.0.1 --port 4173 --strictPort\" http://127.0.0.1:4173 cypress:run"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.56.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "cypress": "^15.13.0",
    "start-server-and-test": "^3.0.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
