# App data target for frontend runtime: local | dev
VITE_APP_ENV=local

# Frontend Supabase credentials (local target)
VITE_SUPABASE_URL_LOCAL=https://your-local-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY_LOCAL=your_local_supabase_anon_key

# Frontend Supabase credentials (dev target)
VITE_SUPABASE_URL_DEV=https://your-dev-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY_DEV=your_dev_supabase_anon_key

# Telegram bot notification (used when ending shift)
VITE_TELEGRAM_BOT_TOKEN=your_telegram_bot_token
VITE_TELEGRAM_CHAT_ID=your_telegram_chat_id

# Script credentials for local target
SUPABASE_URL_LOCAL=https://your-local-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY_LOCAL=your_local_service_role_key

# Script credentials for dev target
SUPABASE_URL_DEV=https://your-dev-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY_DEV=your_dev_service_role_key
